{
  "name": "@hanzlabaig-dev/aicli",
  "version": "1.0.0",
  "description": "A production-quality terminal-based AI Coding CLI supporting multiple AI providers",
  "main": "dist/index.js",
  "bin": {
    "aicli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "coding",
    "assistant",
    "terminal",
    "openai",
    "claude",
    "gemini",
    "openrouter"
  ],
  "author": "TheBitForge",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.17.0",
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^16.4.5",
    "enquirer": "^2.4.1",
    "figures": "^3.2.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "ink": "^4.4.1",
    "marked": "^13.0.1",
    "marked-terminal": "^7.1.0",
    "minimatch": "^9.0.5",
    "node-fetch": "^2.7.0",
    "ollama": "^0.5.6",
    "openai": "^4.52.7",
    "ora": "^5.4.1",
    "readline": "^1.3.0",
    "simple-git": "^3.25.0",
    "supports-color": "^8.1.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.14.9",
    "@types/node-fetch": "^2.6.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
